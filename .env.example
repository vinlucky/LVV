# ============================================================
# LVV Office Assistant - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys
# Get Qwen API Key: https://dashscope.console.aliyun.com/apiKey

# --- Qwen / DashScope ---
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Tencent Hunyuan ---
TENCENT_API_KEY=
TENCENT_API_BASE=https://api.hunyuan.cloud.tencent.com/v1

# --- Default AI Provider ---
DEFAULT_PROVIDER=qwen

# --- AI Core Backend ---
AI_CORE_HOST=127.0.0.1
AI_CORE_PORT=8000
AI_CORE_URL=http://127.0.0.1:8000

# --- Web Frontend ---
WEB_PORT=5173